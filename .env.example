# Application
APP_ENV=local
APP_NAME=HUFSOLVE
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
AUTO_CREATE_TABLES=true
AUTO_SEED=true

# Database
DATABASE_URL=sqlite:///./hufsolve.db
# DATABASE_URL=mysql+pymysql://hufsolve_user:hufsolve_password@localhost:3306/hufsolve
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=hufsolve
MYSQL_USER=hufsolve_user
MYSQL_PASSWORD=hufsolve_password

# AWS
QUEUE_BACKEND=local
AWS_REGION=ap-northeast-2
SQS_QUEUE_URL=
SQS_DLQ_URL=
S3_BUCKET_NAME=
ECR_PYTHON_RUNNER_IMAGE=

# Worker
WORKER_POLL_WAIT_SECONDS=10
WORKER_VISIBILITY_TIMEOUT_SECONDS=60
WORKER_MAX_RECEIVE_COUNT=3
JUDGE_DOCKER_IMAGE=judge-python:3.11
JUDGE_BASE_TMP_DIR=/tmp/hufsolve
JUDGE_DEFAULT_TIME_LIMIT_MS=2000
JUDGE_DEFAULT_MEMORY_LIMIT_MB=128
JUDGE_CPU_LIMIT=0.5
JUDGE_PIDS_LIMIT=64
JUDGE_MAX_OUTPUT_BYTES=65536
JUDGE_CONTAINER_STARTUP_GRACE_SECONDS=5
